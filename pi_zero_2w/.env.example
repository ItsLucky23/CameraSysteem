# Pi5 API base URL (must be reachable from Pi Zero)
PI5_BASE_URL=http://192.168.1.10:80

# Node identity (must match Camera.nodeId for this camera)
NODE_ID=pi-zero-2w-cam01
CAMERA_ID=YOUR_CAMERA_ID_FROM_DB

# Must match CAMERA_NODE_SHARED_SECRET on Pi5
NODE_SECRET=REPLACE_WITH_CAMERA_NODE_SHARED_SECRET

# Runtime settings
HARDWARE_ADAPTER=rpi
POLL_INTERVAL_MS=750
TELEMETRY_INTERVAL_SEC=5
COMMAND_BATCH_LIMIT=20
HTTP_TIMEOUT_SEC=8
VERIFY_TLS=true
LOG_LEVEL=INFO

# Camera movement settings
PTZ_STEP=5

# Optional SG90 servo GPIO pins for pan and tilt
# Set these when using Micro Servo 9g (SG90) motors.
PAN_SERVO_GPIO_PIN=12
TILT_SERVO_GPIO_PIN=13

# Optional CPU temp source
CPU_TEMP_PATH=/sys/class/thermal/thermal_zone0/temp

# Optional infrared control GPIO pin
IR_GPIO_PIN=18

# Optional recording commands
# If unset, recordStart/recordStop only update state without launching a process.
RECORDING_START_COMMAND=
RECORDING_STOP_COMMAND=
